<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Item</title>
  </head>
  <body>
    <form action="/add-item" method="POST">
      <label for="title">Title</label>
      <input type="text" id="title" name="title" required />
      <label for="description">Description</label>
      <input type="text" name="description" id="description" required />
      <label for="price">Price</label>
      <input type="number" name="price" id="price" min="1" required />
      <label for="release-year">Release Year</label>
      <input type="date" name="release-year" id="release-year" required />
      <fieldset>
        <legend>Genre</legend>
        <% genres.forEach(genre => { %>
        <input
          type="checkbox"
          name="genres"
          value="<%= genre.genre_id %>"
          id="<%= genre.name %>"
        />
        <label for="<%= genre.name %>"><%= genre.name %></label>
        <% }); %>
      </fieldset>
      <label for="developer-select">Developer: </label>
      <select name="developer-id" id="developer-select">
        <% developers.forEach(developer => { %>
        <option value="<%= developer.developer_id %>">
          <%= developer.name %>
        </option>
        <% }) %>
      </select>
      <button type="submit">Add Item</button>
    </form>
  </body>
</html>
